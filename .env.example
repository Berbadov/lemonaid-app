# DeepSeek API key
DEEPSEEK_API_KEY=

# Local SQLite path
SQLITE_PATH=data/lemonaid.db

# Chroma persistence directory
CHROMA_PERSIST_DIR=chroma_db

# API endpoint exposed to Chrome extension
ANALYZER_API_URL=http://127.0.0.1:8000

# Scraper compliance controls
SCRAPER_USER_AGENT=LemonaidResearchBot/0.1 (+contact@example.com)
SCRAPER_CONCURRENT_REQUESTS=8
SCRAPER_DOWNLOAD_DELAY=0.35
SCRAPER_AUTOTHROTTLE_START_DELAY=0.3
SCRAPER_AUTOTHROTTLE_MAX_DELAY=6.0
SCRAPER_ROBOTSTXT_OBEY=true
